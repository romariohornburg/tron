# Tron Production Environment Configuration
# Copy this file to .env and configure the values

# =============================================================================
# Required Variables
# =============================================================================

# Database password (REQUIRED - use a strong password)
DB_PASSWORD=your-secure-database-password

# API Secret Key (REQUIRED - minimum 32 characters)
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-minimum-32-characters-here

# =============================================================================
# Optional Variables
# =============================================================================

# Database user (default: tron)
DB_USER=tron

# Image tags (default: latest)
# Use specific versions for production stability
API_IMAGE_TAG=0.3.0
PORTAL_IMAGE_TAG=0.3.0

# Port mappings
HTTP_PORT=80
HTTPS_PORT=443

# CORS configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-domain.com

# API URL for Portal (use /api when behind nginx proxy)
API_URL=/api

# SSO / OAuth (identity providers)
# Public URL of the API (used as redirect_uri base for OAuth callbacks)
# Example: https://api.your-domain.com or http://localhost:8000
API_PUBLIC_URL=https://api.your-domain.com

# URL of the Portal (where to redirect after successful social login)
# Example: https://app.your-domain.com or http://localhost:3000
FRONTEND_URL=https://app.your-domain.com

# =============================================================================
# Initial Setup
# =============================================================================

# Skip the initial setup wizard (use for automated deployments)
# If true, you must create the admin user through other means (e.g., scripts)
# Default: false (setup wizard required on first access)
SKIP_SETUP=false

# =============================================================================
# Secrets Encryption
# =============================================================================

# Key for encrypting application secrets stored in the database
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: Keep this key safe! Losing it means losing access to all encrypted secrets
TRON_SECRETS_KEY=

# =============================================================================
# Audit Logging (SIEM Export)
# =============================================================================

# Enable audit logging (default: false)
# When enabled, structured audit events are sent to the configured SIEM endpoint
AUDIT_LOG_ENABLED=false

# SIEM endpoint URL for audit event ingestion
# Example: https://logs.example.com/ingest
AUDIT_SIEM_URL=

# Optional Bearer token for SIEM authentication
AUDIT_SIEM_TOKEN=

# HTTP timeout in seconds for SIEM POST requests (default: 5)
AUDIT_SIEM_TIMEOUT=5

# =============================================================================
# Namespace Protection
# =============================================================================

# Tron uses the fixed prefix 'tron-ns-' for all managed namespaces
# This is NOT configurable for security reasons
# Example: app "my-api" creates namespace "tron-ns-my-api"

# Comma-separated list of additional protected namespaces
# These namespaces cannot be used for application names
# Default protected: kube-system, kube-public, kube-node-lease, default
# Example: PROTECTED_NAMESPACES=monitoring,ingress-nginx,cert-manager
PROTECTED_NAMESPACES=

# =============================================================================
# SSL/HTTPS Configuration (required for --profile ssl)
# =============================================================================

# Your domain name (e.g., tron.example.com)
DOMAIN=your-domain.com

# Email for Let's Encrypt notifications
CERTBOT_EMAIL=admin@your-domain.com
